{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "stylelint": "stylelint --ignore-path .stylelintignore '**/*.{vue,scss}'",
    "stylelint:fix": "stylelint --fix --ignore-path .stylelintignore '**/*.{vue,scss}'",
    "stylelint:staged": "stylelint --fix --ignore-path .stylelintignore",
    "lint": "yarn lint:eslint",
    "lint:eslint": "eslint . --fix",
    "lint:fix": "yarn run lint:eslint",
    "lint:staged": "yarn run lint:eslint"
  },
  "devDependencies": {
    "@nuxt/eslint": "^0.7.5",
    "@nuxtjs/stylelint-module": "^5.0.1",
    "@tanstack/query-persist-client-core": "^5.29.0",
    "@tanstack/vue-query": "^5.27.5",
    "@vueuse/router": "^14.3.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "nuxt": "^4.4.8",
    "postcss-html": "^1.8.1",
    "sass": "^1.101.0",
    "sharp": "^0.33.2",
    "stylelint": "^17.14.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.4.5",
    "vite": "^7",
    "vite-plugin-vuetify": "^2.1.3",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@nuxt/image": "^2.0.0",
    "vuetify": "^4.1.2"
  },
  "optionalDependencies": {
    "lint-staged": "^17.0.8"
  },
  "packageManager": "yarn@4.1.0"
}
