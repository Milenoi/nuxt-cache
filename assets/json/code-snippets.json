    "key": "nitro",
    "file": "server/api/apod.get.ts",
    "html": "<pre class=\"shiki vitesse-dark\" style=\"color:#dbd7caee\" tabindex=\"0\"><code><span class=\"line\"><span style=\"color:#758575DD\">// The Nitro layer wraps Redis in an in-process, stale-while-revalidate cache.</span></span>\n<span class=\"line\"><span style=\"color:#CB7676\">const </span><span style=\"color:#BD976A\">throughNitro</span><span style=\"color:#666666\"> =</span><span style=\"color:#80A665\"> defineCachedFunction</span><span style=\"color:#666666\">(</span><span style=\"color:#BD976A\">throughRedis</span><span style=\"color:#666666\">,</span><span style=\"color:#666666\"> {</span></span>\n<span class=\"line\"><span style=\"color:#B8A965\">  name</span><span style=\"color:#666666\">: </span><span style=\"color:#C98A7D77\">\"</span><span style=\"color:#C98A7D\">apod-detail</span><span style=\"color:#C98A7D77\">\"</span><span style=\"color:#666666\">,</span></span>\n<span class=\"line\"><span style=\"color:#B8A965\">  group</span><span style=\"color:#666666\">: </span><span style=\"color:#C98A7D77\">\"</span><span style=\"color:#C98A7D\">apod-nitro</span><span style=\"color:#C98A7D77\">\"</span><span style=\"color:#666666\">,</span></span>\n<span class=\"line\"><span style=\"color:#80A665\">  getKey</span><span style=\"color:#666666\">: (</span><span style=\"color:#BD976A\">d</span><span style=\"color:#666666\">: </span><span style=\"color:#5DA994\">string</span><span style=\"color:#666666\">) => </span><span style=\"color:#BD976A\">d</span><span style=\"color:#666666\">,</span></span>\n<span class=\"line\"><span style=\"color:#B8A965\">  maxAge</span><span style=\"color:#666666\">: </span><span style=\"color:#4C9A91\">30</span><span style=\"color:#666666\">,          </span><span style=\"color:#758575DD\">// fresh for 30s — answers directly</span></span>\n<span class=\"line\"><span style=\"color:#B8A965\">  staleMaxAge</span><span style=\"color:#666666\">: </span><span style=\"color:#4C9A91\">86400</span><span style=\"color:#666666\">,  </span><span style=\"color:#758575DD\">// then serves the stale value instantly...</span></span>\n<span class=\"line\"><span style=\"color:#B8A965\">  swr</span><span style=\"color:#666666\">: </span><span style=\"color:#4D9375\">true</span><span style=\"color:#666666\">,           </span><span style=\"color:#758575DD\">// ...and refreshes in the background, no request waits</span></span>\n<span class=\"line\"><span style=\"color:#666666\">});</span></span>\n<span class=\"line\"></span>\n<span class=\"line\"><span style=\"color:#758575DD\">// A warm hit never leaves the server process, beating the Redis network hop.</span></span>\n<span class=\"line\"><span style=\"color:#CB7676\">const </span><span style=\"color:#BD976A\">entry</span><span style=\"color:#666666\"> =</span><span style=\"color:#4D9375\"> await</span><span style=\"color:#80A665\"> throughNitro</span><span style=\"color:#666666\">(</span><span style=\"color:#BD976A\">date</span><span style=\"color:#666666\">);</span></span></code></pre>"
  },
